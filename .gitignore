# Python bytecode and interpreter caches
__pycache__/
*.py[cod]
*$py.class

# Native extension and packaging artifacts
*.so
*.pyd
*.dll
*.egg
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# Virtual environments and local Python tooling
.venv/
venv/
env/
ENV/
.python-version

# Test, lint, type-check, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Jupyter and local notebook state
.ipynb_checkpoints/

# IDE and editor settings
.idea/
.vscode/
*.suo
*.user
*.userossc
*.sln.docstates
*.swp
*.swo
*~

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini

# Project-local scratch and generated output
.pycache_temp/
output/*
!output/.gitkeep

# Common rendered/exported media artifacts
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.gif
